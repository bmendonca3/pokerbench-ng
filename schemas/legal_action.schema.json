{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokerbench-ng.local/schemas/legal_action.schema.json",
  "title": "PokerBench-NG LegalAction",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "enum": ["fold", "check", "call", "bet", "raise", "all_in"] },
    "amount_bb": { "type": "number", "minimum": 0 },
    "min_to_bb": { "type": "number", "minimum": 0 },
    "max_to_bb": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}

