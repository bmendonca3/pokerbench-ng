{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokerbench-ng.local/schemas/leaderboard.schema.json",
  "title": "PokerBench-NG LeaderboardEntry",
  "type": "object",
  "required": ["schema_version", "benchmark_version", "track_id", "agent_name", "primary_score", "summary", "reproducibility"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "benchmark_version": { "type": "string" },
    "track_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "primary_score": { "type": "number" },
    "summary": { "type": "object" },
    "reproducibility": {
      "type": "object",
      "required": ["benchmark_version", "package_version", "scoring_version", "agent_manifest_path", "agent_manifest_hash", "inputs"],
      "properties": {
        "benchmark_version": { "type": "string" },
        "package_version": { "type": "string" },
        "scoring_version": { "type": "string" },
        "agent_manifest_path": { "type": "string" },
        "agent_manifest_hash": { "type": "string" },
        "inputs": { "type": "object" },
        "seed_schedule_hash": { "type": "string" },
        "seed_count": { "type": "integer" },
        "opponent": { "type": "object" }
      }
    }
  }
}
